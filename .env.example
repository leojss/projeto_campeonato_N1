# ============================================================
# Web App Controle de Apostas N1 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA faça commit do arquivo .env com segredos reais.
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://sua-url-do-supabase.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# --- IA (Google Gemini Vision) ---
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua-gemini-api-key-aqui
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash

# --- Configurações do sistema ---
TIMEZONE=America/Sao_Paulo
# Confidence mínima aceita pela IA para aprovar aposta automaticamente (0.0 a 1.0)
MIN_OCR_CONFIDENCE=0.75

# --- Streamlit ---
STREAMLIT_PORT=8501
